  --query "[?tags.\"kubernetes.io-cluster-${INFRA_TAG}\" == 'owned'].{DiskName:name, ResourceGroup:resourceGroup, SizeGB:diskSizeGb, Status:diskState, AttachedToNode:managedBy}" \
  --output table

