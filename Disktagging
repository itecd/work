#!/bin/bash

INPUT_FILE="disks.csv"

# diskName,resourceGroup,tags

while IFS=',' read -r DISK_NAME RESOURCE_GROUP TAGS
do
  az disk update \
    --name "$DISK_NAME" \
    --resource-group "$RESOURCE_GROUP" \
    --set tags={$TAGS}

  echo "Tagged: $DISK_NAME"

done < "$INPUT_FILE"


