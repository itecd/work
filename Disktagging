#!/bin/bash

RESOURCE_GROUP="your_resource_group_name"

INFRA_TAG=$(oc get infrastructure cluster -o jsonpath='{.status.infrastructureName}')

az disk list \
  --resource-group "$RESOURCE_GROUP" \
  --query "[?tags.\"kubernetes.io-cluster-${INFRA_TAG}\" == 'owned'].name" \
  --output tsv | while read -r DISK_NAME; do

    echo "Safely adding tags to: $DISK_NAME"

    # Use --add instead of --tags to preserve existing tags
    az disk update \
        --name "$DISK_NAME" \
        --resource-group "$RESOURCE_GROUP" \
        --add tags.Environment="Production" tags.Project="OpenShift" tags.Owner="DevOps"

    echo "Successfully updated $DISK_NAME"
    echo "-----------------------------------"
done



